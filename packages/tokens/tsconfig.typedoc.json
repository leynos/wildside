{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["build/**/*.js", "build-utils/**/*.js", "src/utils/**/*.js"],
  "exclude": ["node_modules"]
}
