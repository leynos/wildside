{
  "devDependencies": {
    "@biomejs/biome": "^2.3.1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "markdownlint-cli": "^0.45.0",
    "puppeteer": "^23.11.1",
    "validator": "^13.15.23",
    "vite": "^7.3.2"
  },
  "name": "myapp",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend-pwa",
    "packages/*"
  ],
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r run build",
    "fmt": "node ./scripts/run-workspace-script.mjs fmt",
    "lint": "node ./scripts/run-workspace-script.mjs lint",
    "typecheck": "node ./scripts/run-workspace-script.mjs typecheck",
    "test": "node ./scripts/run-workspace-script.mjs test",
    "audit": "node ./scripts/run-workspace-script.mjs audit",
    "audit:validate": "node security/validate-audit.js"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "5.0.1",
      "brace-expansion@<5.0.5": "5.0.5",
      "ajv": "8.18.0",
      "glob": "11.1.0",
      "js-yaml": "4.1.1",
      "lodash": "4.18.1",
      "markdown-it": "14.1.1",
      "minimatch": "10.2.3",
      "lodash-es": "4.18.1",
      "pino": "9.13.1",
      "qs": "6.14.2",
      "rollup": "4.59.0",
      "basic-ftp": "5.2.1",
      "dompurify": "3.3.2",
      "tar-fs": "3.1.1",
      "validator": "13.15.23",
      "ws": "8.18.3",
      "yauzl": "3.2.1",
      "yaml@<1.10.3": "1.10.3",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=3.0.0 <3.0.2": "3.0.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "smol-toml@<1.6.1": "1.6.1"
    }
  }
}
